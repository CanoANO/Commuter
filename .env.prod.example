FLASK_ENV=production
LOG_LEVEL=INFO
APP_TIMEZONE=America/Toronto

POSTGRES_USER=commuter
POSTGRES_PASSWORD=REPLACE_ME
POSTGRES_DB=commuter_db
DB_HOST=db
DB_PORT=5432
DATABASE_URL=postgresql://commuter:REPLACE_ME@db:5432/commuter_db

REDIS_HOST=redis
