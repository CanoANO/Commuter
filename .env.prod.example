AMQP_URL=amqp://commuter:REPLACE_ME@rabbitmq:5672/%2F

GOOGLE_MAPS_API_KEY=REPLACE_ME

WEB_GUNICORN_WORKERS=4
WEB_GUNICORN_TIMEOUT=120

