FLASK_ENV=development
LOG_LEVEL=DEBUG
APP_TIMEZONE=America/Toronto

POSTGRES_USER=commuter
POSTGRES_PASSWORD=commuter_password
POSTGRES_DB=commuter_db
DB_HOST=db
DB_PORT=5432
DATABASE_URL=postgresql://commuter:commuter_password@db:5432/commuter_db

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

RABBITMQ_USER=commuter
RABBITMQ_PASSWORD=commuter_password
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
AMQP_URL=amqp://commuter:commuter_password@rabbitmq:5672/%2F

GOOGLE_MAPS_API_KEY=

WEB_GUNICORN_WORKERS=2
WEB_GUNICORN_TIMEOUT=120
